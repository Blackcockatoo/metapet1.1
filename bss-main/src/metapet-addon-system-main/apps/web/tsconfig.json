{
  "extends": "../../packages/config/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@bluesnake-studios/addon-core": ["../../packages/addon-core/src/index.ts"],
      "@bluesnake-studios/addon-core/*": ["../../packages/addon-core/src/*"],
      "@bluesnake-studios/addon-crypto": ["../../packages/addon-crypto/src/index.ts"],
      "@bluesnake-studios/addon-crypto/*": ["../../packages/addon-crypto/src/*"],
      "@bluesnake-studios/addon-minting": ["../../packages/addon-minting/src/index.ts"],
      "@bluesnake-studios/addon-minting/*": ["../../packages/addon-minting/src/*"],
      "@bluesnake-studios/addon-store": ["../../packages/addon-store/src/index.ts"],
      "@bluesnake-studios/addon-store/*": ["../../packages/addon-store/src/*"],
      "@bluesnake-studios/config": ["../../packages/config/src/index.ts"],
      "@bluesnake-studios/config/*": ["../../packages/config/src/*"],
      "@bluesnake-studios/moss60": ["../../packages/moss60/src/index.ts"],
      "@bluesnake-studios/moss60/*": ["../../packages/moss60/src/*"],
      "@bluesnake-studios/ui": ["../../packages/ui/src/index.ts"],
      "@bluesnake-studios/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
